{
  "name": "my-home-page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "sync:dev-log": "node scripts/sync_dev_env_changelog.mjs",
    "prebuild": "npm run sync:dev-log && node -e \"if(!process.env.CI){const{execSync}=require('child_process');execSync('npm run import:note',{stdio:'inherit'})}\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "import:note": "node scripts/import_note_articles.mjs"
  },
  "dependencies": {
    "@sindresorhus/slugify": "^3.0.0",
    "gray-matter": "^4.0.3",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
